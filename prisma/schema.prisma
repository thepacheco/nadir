generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Company {
  id        String   @id @default(cuid())
  name      String
  industry  String
  createdAt DateTime @default(now())
  
  // Relations
  items     Item[]
  bids      Bid[]
}

model Item {
  id          String   @id @default(cuid())
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  
  name        String
  type        String   // e.g. "FINISHED_GOOD", "RAW_MATERIAL", "LABOR", "PACKAGING"
  baseCost    Float?   // Only applies if it's a raw material or labor (e.g., $0.50 per apple)
  unit        String   // e.g. "slice", "hour", "unit"
  
  // For recursive BOM
  components  BOM[]    @relation("ParentItem")
  usedIn      BOM[]    @relation("ChildItem")
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BOM {
  id          String   @id @default(cuid())
  
  parentId    String
  parent      Item     @relation("ParentItem", fields: [parentId], references: [id])
  
  childId     String
  child       Item     @relation("ChildItem", fields: [childId], references: [id])
  
  quantity    Float    // How many units of child are needed for 1 unit of parent
}

// ---- Graph Store (ARCHITECTURE.md Part 3.1) ----
// The confirmed ontology made real: object types, sampled object instances,
// and type-level relationships persisted from the mapping pipeline.
// Instance-level edges (this work order → that asset) arrive with the SQL
// schema extractor; sampling only proves the wiring at type level.

model GraphObjectType {
  id          String   @id @default(cuid())
  companyId   String
  name        String   // confirmed business name, e.g. "Work Orders"
  sourceTable String   // raw table/file it came from
  confidence  Float    // computed by the mapper, never invented
  reasoning   String   // newline-joined mapper reasoning (the visible "why")
  createdAt   DateTime @default(now())

  objects GraphObject[]

  @@unique([companyId, sourceTable])
}

model GraphObject {
  id         String          @id @default(cuid())
  companyId  String
  typeId     String
  type       GraphObjectType @relation(fields: [typeId], references: [id], onDelete: Cascade)
  sourceKey  String          // key value in the source row ("" when the table has no key column)
  attributes String          // JSON of the sampled source row
  firstSeen  DateTime        @default(now())
  lastSeen   DateTime        @default(now())
}

model GraphRelationship {
  id          String   @id @default(cuid())
  companyId   String
  fromTable   String
  fromColumn  String
  toTable     String
  toColumn    String
  label       String   // e.g. "work order → asset"
  matchRate   Float    // value-overlap on sampled rows at confirm time
  confirmedBy String?  // user who confirmed; null = machine-proposed only
  createdAt   DateTime @default(now())

  @@unique([companyId, fromTable, fromColumn, toTable, toColumn])
}

model AuditEntry {
  id        String   @id @default(cuid())
  companyId String?
  actor     String
  action    String   // e.g. "mapping.persisted"
  detail    String   // plain-English description of what changed
  createdAt DateTime @default(now())
}

model Bid {
  id              String   @id @default(cuid())
  companyId       String
  company         Company  @relation(fields: [companyId], references: [id])
  
  clientName      String
  description     String
  
  predictedCost   Float
  appliedMargin   Float    // e.g. 0.20 for 20%
  finalBidPrice   Float
  
  createdAt       DateTime @default(now())
}
